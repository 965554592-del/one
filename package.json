{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build:client": "vite build",
    "build:client:full": "vite build && node scripts/prerender.mjs && node scripts/generate-sitemap.mjs",
    "build:server": "esbuild server.ts --bundle --platform=node --format=esm --target=node18 --packages=external --outfile=dist-server/server.mjs",
    "build": "npm run build:client && npm run build:server",
    "prerender": "node scripts/prerender.mjs",
    "sitemap": "node scripts/generate-sitemap.mjs",
    "start": "cross-env NODE_ENV=production node dist-server/server.mjs",
    "preview": "vite preview",
    "clean": "rm -rf dist dist-server",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "ffmpeg-static": "^5.3.0",
    "firebase": "^12.12.0",
    "fluent-ffmpeg": "^2.1.3",
    "framer-motion": "^12.38.0",
    "i18next": "^26.0.5",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.72.1",
    "react-i18next": "^17.0.3",
    "react-router-dom": "^7.14.1",
    "resend": "^6.12.3",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "vite": "^6.2.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/serve-handler": "^6.1.4",
    "adm-zip": "^0.5.17",
    "autoprefixer": "^10.4.21",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.0",
    "firebase-admin": "^13.10.0",
    "puppeteer": "^25.0.4",
    "serve-handler": "^6.1.7",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "xlsx": "^0.18.5"
  }
}
