# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_WHATSAPP_NUMBER: The WhatsApp number used for automated inquiries.
# Format: Country code followed by the number without spaces or symbols (e.g., 861234567890).
VITE_WHATSAPP_NUMBER="861234567890"

# --- Frontend build-time variables ---
# VITE_API_BASE_URL: When the frontend is hosted on a different origin than the backend
# (e.g. frontend on SiteGround, backend on Render), set this to the absolute backend URL.
# Leave empty for same-origin / dev (vite middleware).
VITE_API_BASE_URL=""

# --- Backend runtime variables (used by server.ts) ---
# PORT: Auto-injected by most PaaS (Render, Railway). Defaults to 3000.
# PORT=3000
# CORS_ORIGIN: Comma-separated whitelist of origins allowed to call the API.
# Use "*" to allow any origin (dev only). Example: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGIN="*"
# PUBLIC_BASE_URL: Absolute URL of the backend, used to build absolute upload URLs
# so the (cross-origin) frontend can load /uploads/<file>. Example: https://vida-api.onrender.com
PUBLIC_BASE_URL=""

# --- Analytics & Live Chat ---
# VITE_META_PIXEL_ID: Meta (Facebook) Pixel ID. Leave empty to disable.
# When set, the app auto-fires `PageView` on every route change and `Lead` on
# successful inquiry-form submission.
VITE_META_PIXEL_ID=""

# VITE_WORKING_HOURS: WhatsApp/online-chat business hours.
# Format: "MON-FRI 09:00-18:00;SAT 10:00-14:00"
VITE_WORKING_HOURS="MON-FRI 09:00-18:00"
# IANA timezone for the schedule above.
VITE_WORKING_HOURS_TZ="Asia/Shanghai"

# VITE_TAWK_PROPERTY_ID / VITE_TAWK_WIDGET_ID: Optional Tawk.to live chat.
# Find them in Tawk.to dashboard -> Administration -> Chat Widget -> Direct Chat Link
# (URL looks like https://tawk.to/chat/<PROPERTY_ID>/<WIDGET_ID>).
# Leave both empty to disable Tawk.to.
VITE_TAWK_PROPERTY_ID=""
VITE_TAWK_WIDGET_ID=""
